generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserType {
  ADMIN
  SALES
  OPERATIONS
  PURCHASING
  FINANCE
}

enum OpportunityStage {
  LEAD
  QUALIFIED
  QUOTED
  WON
  LOST
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  BLOCKED
  DONE
}

enum QuoteStatus {
  DRAFT
  SENT
  ACCEPTED
}

enum EntityType {
  OPPORTUNITY
  QUOTE
  SALES_ORDER
  SALES_ORDER_LINE
  PURCHASE_ORDER
  PROJECT
  JOB
}

model User {
  id           String       @id @default(cuid())
  email        String       @unique
  name         String
  passwordHash String
  type         UserType
  active       Boolean      @default(true)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  tasks        Task[]
}

model Customer {
  id            String        @id @default(cuid())
  name          String
  email         String?
  phone         String?
  opportunities Opportunity[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model Vendor {
  id        String          @id @default(cuid())
  name      String
  email     String?
  phone     String?
  poLines   PurchaseOrderLine[]
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
}

model Opportunity {
  id                  String             @id @default(cuid())
  name                String
  stage               OpportunityStage   @default(LEAD)
  customerId          String
  ownerId             String?
  description         String?
  source              String?
  priority            String?
  expectedCloseDate   DateTime?
  probability         Decimal?           @db.Decimal(5, 2)
  estimatedValue      Decimal?           @db.Decimal(12, 2)
  customerPoNumber    String?
  customerPoDate      DateTime?
  dueDate             DateTime?
  inHandDate          DateTime?
  customer            Customer           @relation(fields: [customerId], references: [id])
  quotes              Quote[]
  salesOrders         SalesOrder[]
  projects            Project[]
  jobs                Job[]
  tasks               Task[]
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
}

model Quote {
  id                            String      @id @default(cuid())
  quoteNumber                   String      @unique
  opportunityId                 String
  status                        QuoteStatus @default(DRAFT)
  title                         String?
  description                   String?
  txnDate                       DateTime?
  txnNumber                     String?
  totalPriceInDollars           Decimal?    @db.Decimal(12, 2)
  totalTaxInDollars             Decimal?    @db.Decimal(12, 2)
  totalPriceWithTaxInDollars    Decimal?    @db.Decimal(12, 2)
  workflowState                 String?     @default("draft")
  expiryDate                    DateTime?
  nextContactDate               DateTime?
  potentialClosingDate          DateTime?
  closingPotential              Decimal?    @db.Decimal(5, 2)
  customerPoNumber              String?
  customerPoDate                DateTime?
  autoExpire                    Boolean     @default(false)
  downpaymentPercent            Decimal?    @db.Decimal(5, 2)
  shippingTracking              String?
  shippingDate                  DateTime?
  lastNote                      String?
  lastEmailedDate               DateTime?
  quoteFor                      String?
  customerNote                  String?
  site                          String?
  quickQuote                    Boolean     @default(false)
  dueDate                       DateTime?
  inHandDate                    DateTime?
  primaryContactName            String?
  primaryContactEmail           String?
  primaryContactPhoneWithExt    String?
  primarySalesRepName           String?
  companyName                   String?
  opportunity                   Opportunity @relation(fields: [opportunityId], references: [id])
  lines                         QuoteLine[]
  salesOrders                   SalesOrder[]
  tasks                         Task[]
  createdAt                     DateTime    @default(now())
  updatedAt                     DateTime    @updatedAt
}

model QuoteLine {
  id                      String   @id @default(cuid())
  quoteId                 String
  description             String
  qty                     Int
  unitPrice               Decimal  @db.Decimal(12, 2)
  attributeValues         Json?
  productId               String?
  name                    String?
  fullDescription         String?
  uom                     String?
  costInDollars           Decimal? @db.Decimal(12, 2)
  suggestedPriceInDollars Decimal? @db.Decimal(12, 2)
  totalPriceInDollars     Decimal? @db.Decimal(12, 2)
  totalCostInDollars      Decimal? @db.Decimal(12, 2)
  totalTaxInDollars       Decimal? @db.Decimal(12, 2)
  workflowState           String?
  saleType                String?
  taxable                 Boolean  @default(false)
  taxName                 String?
  taxRate                 Decimal? @db.Decimal(6, 4)
  priceOverride           Boolean  @default(false)
  quote                   Quote    @relation(fields: [quoteId], references: [id])
  product                 Product? @relation(fields: [productId], references: [id])
}

model Product {
  id              String             @id @default(cuid())
  sku             String             @unique
  name            String
  category        String?
  uom             String?            @default("EA")
  description     String?
  salePrice       Decimal            @db.Decimal(12, 2)
  costPrice       Decimal?           @db.Decimal(12, 2)
  pricingFormula  String?
  taxable         Boolean            @default(true)
  active          Boolean            @default(true)
  attributes      ProductAttribute[]
  quoteLines      QuoteLine[]
  salesOrderLines SalesOrderLine[]
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
}

enum AttributeInputType {
  TEXT
  NUMBER
  SELECT
  BOOLEAN
}

model ProductAttribute {
  id          String             @id @default(cuid())
  productId   String
  code        String
  name        String
  inputType   AttributeInputType @default(TEXT)
  required    Boolean            @default(false)
  options     Json?
  defaultValue String?
  sortOrder   Int                @default(0)
  product     Product            @relation(fields: [productId], references: [id])

  @@unique([productId, code])
}

model SalesOrder {
  id            String           @id @default(cuid())
  orderNumber   String           @unique
  opportunityId String
  sourceQuoteId String?
  opportunity   Opportunity      @relation(fields: [opportunityId], references: [id])
  sourceQuote   Quote?           @relation(fields: [sourceQuoteId], references: [id])
  lines         SalesOrderLine[]
  tasks         Task[]
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
}

model SalesOrderLine {
  id           String              @id @default(cuid())
  salesOrderId String
  description  String
  qty          Int
  unitPrice    Decimal             @db.Decimal(12, 2)
  attributeValues Json?
  productId    String?
  salesOrder   SalesOrder          @relation(fields: [salesOrderId], references: [id])
  product      Product?            @relation(fields: [productId], references: [id])
  poLines      PurchaseOrderLine[]
}

model PurchaseOrder {
  id          String              @id @default(cuid())
  poNumber    String              @unique
  opportunityId String?
  lines       PurchaseOrderLine[]
  tasks       Task[]
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
}

model PurchaseOrderLine {
  id              String         @id @default(cuid())
  purchaseOrderId String
  vendorId        String
  salesOrderLineId String?
  description     String
  qty             Int
  unitCost        Decimal        @db.Decimal(12, 2)
  purchaseOrder   PurchaseOrder  @relation(fields: [purchaseOrderId], references: [id])
  vendor          Vendor         @relation(fields: [vendorId], references: [id])
  salesOrderLine  SalesOrderLine? @relation(fields: [salesOrderLineId], references: [id])
}

model Project {
  id            String       @id @default(cuid())
  name          String
  opportunityId String
  opportunity   Opportunity  @relation(fields: [opportunityId], references: [id])
  tasks         Task[]
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}

model Job {
  id            String       @id @default(cuid())
  name          String
  opportunityId String
  opportunity   Opportunity  @relation(fields: [opportunityId], references: [id])
  tasks         Task[]
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}

model Task {
  id         String      @id @default(cuid())
  title      String
  status     TaskStatus  @default(TODO)
  assigneeId String?
  entityType EntityType
  entityId   String
  dueAt      DateTime?
  assignee   User?       @relation(fields: [assigneeId], references: [id])

  opportunityId  String?
  quoteId        String?
  salesOrderId   String?
  purchaseOrderId String?
  projectId      String?
  jobId          String?

  opportunity   Opportunity?  @relation(fields: [opportunityId], references: [id])
  quote         Quote?        @relation(fields: [quoteId], references: [id])
  salesOrder    SalesOrder?   @relation(fields: [salesOrderId], references: [id])
  purchaseOrder PurchaseOrder? @relation(fields: [purchaseOrderId], references: [id])
  project       Project?      @relation(fields: [projectId], references: [id])
  job           Job?          @relation(fields: [jobId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
