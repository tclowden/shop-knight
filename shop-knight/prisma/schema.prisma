generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserType {
  SUPER_ADMIN
  ADMIN
  SALES
  SALES_REP
  PROJECT_MANAGER
  DESIGNER
  OPERATIONS
  PURCHASING
  FINANCE
}

enum OpportunityStage {
  LEAD
  QUALIFIED
  QUOTED
  WON
  LOST
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  BLOCKED
  DONE
}

enum TemplateAssigneeMode {
  UNASSIGNED
  SPECIFIC_USER
  PM
  PROJECT_COORDINATOR
}

enum QuoteStatus {
  DRAFT
  SENT
  ACCEPTED
}

enum EntityType {
  OPPORTUNITY
  QUOTE
  SALES_ORDER
  SALES_ORDER_LINE
  PURCHASE_ORDER
  PROJECT
  JOB
  CUSTOMER
  VENDOR
  PRODUCT
  USER
}

enum ProofStatus {
  PENDING
  APPROVED
  REVISIONS_REQUESTED
}

enum TripStatus {
  PLANNING
  PRE_TRAVEL
  IN_TRANSIT
  ON_SITE
  RETURNED
  CANCELED
}

enum TravelSegmentType {
  FLIGHT
  HOTEL
  CAR
  GROUND
  OTHER
}

enum PerDiemRequestStatus {
  NEW
  IN_REVIEW
  COMPLETE
  CANCELED
}

enum ExpenseReportStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
  REIMBURSED
}

enum AmexTransactionStatus {
  UNMATCHED
  MATCHED
  IGNORED
}

enum NotificationEvent {
  NOTE_MENTION
  TASK_ASSIGNED
  OPPORTUNITY_ROLE_ASSIGNED
  QUOTE_ROLE_ASSIGNED
  SALES_ORDER_ROLE_ASSIGNED
}

enum PurchaseMethod {
  CREDIT_CARD
  ON_ACCOUNT
}

enum TimeEntryStatus {
  PENDING
  APPROVED
  REJECTED
}

enum TimeEntrySourceType {
  SALES_ORDER
  QUOTE
  JOB
}

model Company {
  id                   String                @id @default(cuid())
  name                 String
  slug                 String                @unique
  active               Boolean               @default(true)
  users                UserCompany[]
  activeUsers          User[]                @relation("ActiveCompanyUsers")
  customRoles          CustomRole[]
  customers            Customer[]
  vendors              Vendor[]
  opportunities        Opportunity[]
  quotes               Quote[]
  salesOrders          SalesOrder[]
  jobs                 Job[]
  products             Product[]
  machines             Machine[]
  substrates           Substrate[]
  inventoryItems       InventoryItem[]
  inventoryReservations InventoryReservation[]
  productInventoryRequirements ProductInventoryRequirement[]
  salesOrderStatuses   SalesOrderStatus[]
  taskTemplates        TaskTemplate[]
  jobWorkflowTemplates JobWorkflowTemplate[]
  jobWorkflowRuns      JobWorkflowRun[]
  travelers            Traveler[]
  trips                Trip[]
  perDiemRequests      PerDiemRequest[]
  expenseReports       ExpenseReport[]
  amexTransactions     AmexTransaction[]
  notificationPreferences NotificationPreference[]
  departments          Department[]
  titles               Title[]
  productCategories    ProductCategory[]
  incomeAccounts       IncomeAccount[]
  timeEntries          TimeEntry[]
  payPeriodLocks       PayPeriodLock[]
  payrollExportConfig  PayrollExportConfig?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
}

model User {
  id                          String             @id @default(cuid())
  email                       String             @unique
  name                        String
  passwordHash                String
  type                        UserType
  phone                       String?
  avatarUrl                   String?
  knownTravelerNumber         String?
  rewardMarriottNumber        String?
  rewardUnitedNumber          String?
  rewardDeltaNumber           String?
  rewardAmericanNumber        String?
  active                      Boolean            @default(true)
  activeCompanyId             String?
  departmentId                String?
  titleId                     String?
  reportsToId                 String?
  isEmployee                  Boolean            @default(true)
  createdAt                   DateTime           @default(now())
  updatedAt                   DateTime           @updatedAt
  tasks                       Task[]
  notes                       Note[]
  companyMemberships          UserCompany[]
  activeCompany               Company?           @relation("ActiveCompanyUsers", fields: [activeCompanyId], references: [id])
  department                  Department?        @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  title                       Title?             @relation(fields: [titleId], references: [id], onDelete: SetNull)
  reportsTo                   User?              @relation("UserReporting", fields: [reportsToId], references: [id], onDelete: SetNull)
  directReports               User[]             @relation("UserReporting")
  customRoles                 UserCustomRole[]
  templateSteps               TaskTemplateStep[] @relation("TemplateSpecificAssignee")
  workflowTemplateSteps       JobWorkflowStep[]  @relation("WorkflowTemplateSpecificAssignee")
  salesRepOpportunities       Opportunity[]      @relation("OpportunitySalesRep")
  projectManagerOpportunities Opportunity[]      @relation("OpportunityProjectManager")
  salesRepQuotes              Quote[]            @relation("QuoteSalesRep")
  projectManagerQuotes        Quote[]            @relation("QuoteProjectManager")
  salesRepSalesOrders         SalesOrder[]       @relation("SalesOrderSalesRep")
  projectManagerSalesOrders   SalesOrder[]       @relation("SalesOrderProjectManager")
  designerSalesOrders         SalesOrder[]       @relation("SalesOrderDesigner")
  managedTrips                Traveler[]         @relation("TripManager")
  travelerProfiles            Traveler[]
  createdTrips                Trip[]             @relation("TripCreator")
  approvedTrips               Trip[]             @relation("TripApprover")
  createdPerDiemRequests      PerDiemRequest[]   @relation("PerDiemRequestCreator")
  createdExpenseReports       ExpenseReport[]    @relation("ExpenseReportCreator")
  approvedExpenseReports      ExpenseReport[]    @relation("ExpenseReportApprover")
  employeeExpenseReports      ExpenseReport[]      @relation("ExpenseReportEmployee")
  assignedWorkflowSteps       JobWorkflowStepRun[] @relation("WorkflowStepAssignee")
  noteMentions                NoteMention[]
  notificationPreferences     NotificationPreference[]
  timeEntries                 TimeEntry[]           @relation("TimeEntryUser")
  approvedTimeEntries         TimeEntry[]           @relation("TimeEntryApprover")
  editedTimeEntries           TimeEntry[]           @relation("TimeEntryEditor")
  payPeriodLocks              PayPeriodLock[]       @relation("PayPeriodLockCreator")
}

model Department {
  id           String        @id @default(cuid())
  companyId    String?
  name         String
  active       Boolean       @default(true)
  company      Company?      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  users        User[]
  opportunities Opportunity[]
  quotes       Quote[]
  salesOrders  SalesOrder[]
  products     Product[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@unique([companyId, name])
}

model Title {
  id        String    @id @default(cuid())
  companyId String?
  name      String
  active    Boolean   @default(true)
  company   Company?  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  users     User[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@unique([companyId, name])
}

model ProductCategory {
  id        String    @id @default(cuid())
  companyId String?
  name      String
  active    Boolean   @default(true)
  company   Company?  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  products  Product[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@unique([companyId, name])
}

model IncomeAccount {
  id          String    @id @default(cuid())
  companyId   String?
  code        String
  name        String
  description String?
  active      Boolean   @default(true)
  company     Company?  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  products    Product[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([companyId, code])
}

model CustomRole {
  id              String           @id @default(cuid())
  companyId       String?
  name            String
  active          Boolean          @default(true)
  permissions     Json?
  company         Company?         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  userAssignments UserCustomRole[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@unique([companyId, name])
}

model UserCompany {
  userId    String
  companyId String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@id([userId, companyId])
}

model UserCustomRole {
  userId String
  roleId String
  user   User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   CustomRole @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
}

model Customer {
  id            String        @id @default(cuid())
  companyId     String?
  name          String
  email         String?
  phone         String?
  paymentTerms  String?
  additionalFeePercent Decimal @default(0) @db.Decimal(5, 2)
  company       Company?      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  opportunities Opportunity[]
  contacts      CustomerContact[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model CustomerContact {
  id         String    @id @default(cuid())
  customerId String
  name       String
  email      String?
  phone      String?
  title      String?
  customer   Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([customerId, name])
}

model Vendor {
  id        String              @id @default(cuid())
  companyId String?
  name      String
  email     String?
  phone     String?
  company   Company?            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  poLines   PurchaseOrderLine[]
  salesOrderPurchaseItems SalesOrderPurchaseItem[]
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt
}

model Opportunity {
  id                String           @id @default(cuid())
  companyId         String?
  name              String
  stage             OpportunityStage @default(LEAD)
  customerId        String
  ownerId           String?
  salesRepId        String?
  projectManagerId  String?
  departmentId      String?
  description       String?
  source            String?
  priority          String?
  expectedCloseDate DateTime?
  probability       Decimal?         @db.Decimal(5, 2)
  estimatedValue    Decimal?         @db.Decimal(12, 2)
  customerPoNumber  String?
  customerPoDate    DateTime?
  dueDate           DateTime?
  inHandDate        DateTime?
  company           Company?         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customer          Customer         @relation(fields: [customerId], references: [id])
  salesRep          User?            @relation("OpportunitySalesRep", fields: [salesRepId], references: [id])
  projectManager    User?            @relation("OpportunityProjectManager", fields: [projectManagerId], references: [id])
  department        Department?      @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  quotes            Quote[]
  salesOrders       SalesOrder[]
  projects          Project[]
  jobs              Job[]
  tasks             Task[]
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
}

model Quote {
  id                         String       @id @default(cuid())
  companyId                  String?
  quoteNumber                String
  opportunityId              String
  status                     QuoteStatus  @default(DRAFT)
  title                      String?
  description                String?
  txnDate                    DateTime?
  quoteDate                  DateTime?
  txnNumber                  String?
  customerContactRole        String?
  billingAddress             String?
  billingAttentionTo         String?
  shippingAddress            String?
  shippingAttentionTo        String?
  installAddress             String?
  salesRepId                 String?
  projectManagerId           String?
  departmentId               String?
  totalPriceInDollars        Decimal?     @db.Decimal(12, 2)
  totalTaxInDollars          Decimal?     @db.Decimal(12, 2)
  totalPriceWithTaxInDollars Decimal?     @db.Decimal(12, 2)
  workflowState              String?      @default("draft")
  expiryDate                 DateTime?
  nextContactDate            DateTime?
  potentialClosingDate       DateTime?
  closingPotential           Decimal?     @db.Decimal(5, 2)
  customerPoNumber           String?
  customerPoDate             DateTime?
  autoExpire                 Boolean      @default(false)
  downpaymentPercent         Decimal?     @db.Decimal(5, 2)
  shippingTracking           String?
  shippingDate               DateTime?
  lastNote                   String?
  lastEmailedDate            DateTime?
  quoteFor                   String?
  customerNote               String?
  site                       String?
  quickQuote                 Boolean      @default(false)
  dueDate                    DateTime?
  inHandDate                 DateTime?
  primaryContactName         String?
  primaryContactEmail        String?
  primaryContactPhoneWithExt String?
  primarySalesRepName        String?
  companyName                String?
  company                    Company?     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  opportunity                Opportunity  @relation(fields: [opportunityId], references: [id])
  salesRep                   User?        @relation("QuoteSalesRep", fields: [salesRepId], references: [id])
  projectManager             User?        @relation("QuoteProjectManager", fields: [projectManagerId], references: [id])
  department                 Department?  @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  lines                      QuoteLine[]
  salesOrders                SalesOrder[]
  tasks                      Task[]
  timeEntries                TimeEntry[]
  createdAt                  DateTime     @default(now())
  updatedAt                  DateTime     @updatedAt

  @@unique([companyId, quoteNumber])
}

model QuoteLine {
  id                      String   @id @default(cuid())
  quoteId                 String
  description             String
  qty                     Int
  unitPrice               Decimal  @db.Decimal(12, 2)
  sortOrder               Int      @default(0)
  parentLineId            String?
  collapsed               Boolean  @default(false)
  attributeValues         Json?
  productId               String?
  name                    String?
  fullDescription         String?
  uom                     String?
  costInDollars           Decimal? @db.Decimal(12, 2)
  suggestedPriceInDollars Decimal? @db.Decimal(12, 2)
  totalPriceInDollars     Decimal? @db.Decimal(12, 2)
  totalCostInDollars      Decimal? @db.Decimal(12, 2)
  totalTaxInDollars       Decimal? @db.Decimal(12, 2)
  workflowState           String?
  saleType                String?
  taxable                 Boolean  @default(false)
  taxName                 String?
  taxRate                 Decimal? @db.Decimal(6, 4)
  priceOverride           Boolean  @default(false)
  quote                   Quote    @relation(fields: [quoteId], references: [id])
  product                 Product? @relation(fields: [productId], references: [id])
  proofs                  Proof[]
}

model Product {
  id               String             @id @default(cuid())
  companyId        String?
  sku              String
  name             String
  type             String?
  departmentId     String?
  incomeAccountId  String?
  categoryId       String?
  category         String?
  uom              String?            @default("EA")
  description      String?
  salePrice        Decimal            @db.Decimal(12, 2)
  costPrice        Decimal?           @db.Decimal(12, 2)
  gpmPercent       Decimal?           @db.Decimal(5, 2)
  pricingType      ProductPricingType @default(BASIC)
  pricingFormula   String?
  company          Company?           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  department       Department?        @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  incomeAccount    IncomeAccount?     @relation(fields: [incomeAccountId], references: [id], onDelete: SetNull)
  productCategory  ProductCategory?   @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  taxable          Boolean            @default(true)
  active           Boolean            @default(true)
  attributes       ProductAttribute[]
  pricingGrid      ProductPricingGrid?
  inventoryRequirements ProductInventoryRequirement[]
  quoteLines       QuoteLine[]
  salesOrderLines  SalesOrderLine[]
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  @@unique([companyId, sku])
  @@index([companyId, categoryId])
  @@index([companyId, incomeAccountId])
  @@index([companyId, departmentId])
}

enum ProductPricingType {
  BASIC
  FORMULA
  GRID
}

enum AttributeInputType {
  TEXT
  NUMBER
  SELECT
  MULTI_SELECT
  BOOLEAN
}

enum PricingEffectType {
  NONE
  ADD
  MULTIPLY
  OVERRIDE
  FORMULA_VAR
}

model ProductAttribute {
  id           String                   @id @default(cuid())
  productId    String
  code         String
  name         String
  inputType    AttributeInputType       @default(TEXT)
  required      Boolean                  @default(false)
  legacyOptions Json?                    @map("options")
  defaultValue  String?
  sortOrder     Int                      @default(0)
  product       Product                  @relation(fields: [productId], references: [id])
  options       ProductAttributeOption[]

  @@unique([productId, code])
}

model ProductAttributeOption {
  id               String            @id @default(cuid())
  attributeId      String
  label            String
  value            String?
  sortOrder        Int               @default(0)
  priceEffectType  PricingEffectType @default(NONE)
  priceEffectValue Decimal?          @db.Decimal(12, 4)
  costEffectValue  Decimal?          @db.Decimal(12, 4)
  formulaVarName   String?
  active           Boolean           @default(true)
  attribute        ProductAttribute  @relation(fields: [attributeId], references: [id], onDelete: Cascade)

  @@index([attributeId, sortOrder])
}

model ProductPricingGrid {
  id         String                  @id @default(cuid())
  productId  String                  @unique
  xAxisLabel String?
  yAxisLabel String?
  xBreaks    Json
  yBreaks    Json
  product    Product                 @relation(fields: [productId], references: [id], onDelete: Cascade)
  cells      ProductPricingGridCell[]
}

model ProductPricingGridCell {
  id        String             @id @default(cuid())
  gridId    String
  xIndex    Int
  yIndex    Int
  unitPrice Decimal            @db.Decimal(12, 4)
  grid      ProductPricingGrid @relation(fields: [gridId], references: [id], onDelete: Cascade)

  @@unique([gridId, xIndex, yIndex])
}

model Machine {
  id               String    @id @default(cuid())
  companyId        String?
  name             String
  costPerMinute    Decimal   @db.Decimal(12, 4)
  setupMinutes     Int?
  hourlyCapacity   Int?
  notes            String?
  active           Boolean   @default(true)
  company          Company?  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@unique([companyId, name])
  @@index([companyId, active, name])
}

model Substrate {
  id            String    @id @default(cuid())
  companyId     String?
  name          String
  addOnPrice    Decimal   @db.Decimal(12, 2)
  notes         String?
  active        Boolean   @default(true)
  company       Company?  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@unique([companyId, name])
  @@index([companyId, active, name])
}

model InventoryItem {
  id            String    @id @default(cuid())
  companyId     String?
  itemNumber    String
  name          String
  category      String?
  location      String?
  totalQty      Int       @default(0)
  checkedOutQty Int       @default(0)
  notes         String?
  active        Boolean   @default(true)
  company       Company?  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  reservations  InventoryReservation[]
  productRequirements ProductInventoryRequirement[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@unique([companyId, itemNumber])
  @@index([companyId, active, name])
}

model ProductInventoryRequirement {
  id              String        @id @default(cuid())
  companyId       String?
  productId       String
  inventoryItemId String
  qtyPerUnit      Int           @default(1)
  company         Company?      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  product         Product       @relation(fields: [productId], references: [id], onDelete: Cascade)
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@unique([companyId, productId, inventoryItemId])
  @@index([companyId, productId])
}

model InventoryReservation {
  id              String          @id @default(cuid())
  companyId       String?
  inventoryItemId String
  salesOrderId    String
  salesOrderLineId String?
  quantity        Int
  reservedFrom    DateTime
  reservedTo      DateTime
  notes           String?
  active          Boolean         @default(true)
  company         Company?        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  inventoryItem   InventoryItem   @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)
  salesOrder      SalesOrder      @relation(fields: [salesOrderId], references: [id], onDelete: Cascade)
  salesOrderLine  SalesOrderLine? @relation(fields: [salesOrderLineId], references: [id], onDelete: SetNull)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([companyId, inventoryItemId, reservedFrom, reservedTo])
  @@index([companyId, salesOrderId, active])
}

model SalesOrder {
  id                     String            @id @default(cuid())
  companyId              String?
  orderNumber            String
  opportunityId          String
  sourceQuoteId          String?
  departmentId           String?
  title                  String?
  statusId               String?
  primaryCustomerContact String?
  customerInvoiceContact String?
  billingAddress         String?
  billingAttentionTo     String?
  shippingAddress        String?
  shippingAttentionTo    String?
  installAddress         String?
  shippingMethod         String?
  shippingTracking       String?
  salesOrderDate         DateTime?
  dueDate                DateTime?
  installDate            DateTime?
  shippingDate           DateTime?
  earlyBirdDiscountDate  DateTime?
  advancedReceivingDeadline DateTime?
  shipFromRoarkDate      DateTime?
  travelToSiteStart      DateTime?
  travelToSiteEnd        DateTime?
  outboundShippingFromShowDate DateTime?
  estimatedInvoiceDate   DateTime?
  paymentTerms           String?
  downPaymentType        String?
  downPaymentValue       Decimal?          @db.Decimal(12, 2)
  salesRepId             String?
  projectManagerId       String?
  designerId             String?
  company                Company?          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  opportunity            Opportunity       @relation(fields: [opportunityId], references: [id])
  sourceQuote            Quote?            @relation(fields: [sourceQuoteId], references: [id])
  department             Department?       @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  status                 SalesOrderStatus? @relation(fields: [statusId], references: [id])
  salesRep               User?             @relation("SalesOrderSalesRep", fields: [salesRepId], references: [id])
  projectManager         User?             @relation("SalesOrderProjectManager", fields: [projectManagerId], references: [id])
  designer               User?             @relation("SalesOrderDesigner", fields: [designerId], references: [id])
  lines                  SalesOrderLine[]
  purchaseItems          SalesOrderPurchaseItem[]
  loadLists              LoadList[]
  jobs                   Job[]
  tasks                  Task[]
  timeEntries            TimeEntry[]
  inventoryReservations  InventoryReservation[]
  createdAt              DateTime          @default(now())
  updatedAt              DateTime          @updatedAt

  @@unique([companyId, orderNumber])
}

model SalesOrderStatus {
  id          String       @id @default(cuid())
  companyId   String?
  name        String
  sortOrder   Int          @default(0)
  active      Boolean      @default(true)
  company     Company?     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  salesOrders SalesOrder[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@unique([companyId, name])
}

model SalesOrderLine {
  id              String              @id @default(cuid())
  salesOrderId    String
  description     String
  qty             Int
  unitPrice       Decimal             @db.Decimal(12, 2)
  priceLocked     Boolean             @default(false)
  sortOrder       Int                 @default(0)
  parentLineId    String?
  collapsed       Boolean             @default(false)
  attributeValues Json?
  productId       String?
  salesOrder      SalesOrder          @relation(fields: [salesOrderId], references: [id])
  product         Product?            @relation(fields: [productId], references: [id])
  poLines         PurchaseOrderLine[]
  proofs          Proof[]
  jobs            Job[]
  loadListItems   LoadListItem[]
  inventoryReservations InventoryReservation[]
}

model SalesOrderPurchaseItem {
  id            String         @id @default(cuid())
  salesOrderId  String
  vendorId      String?
  item          String
  description   String?
  qty           Int            @default(1)
  itemCost      Decimal        @db.Decimal(12, 2)
  totalCost     Decimal        @db.Decimal(12, 2)
  purchasedBy   PurchaseMethod @default(CREDIT_CARD)
  poNumber      String?
  receiptRef    String?
  sortOrder     Int            @default(0)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  salesOrder    SalesOrder     @relation(fields: [salesOrderId], references: [id], onDelete: Cascade)
  vendor        Vendor?        @relation(fields: [vendorId], references: [id], onDelete: SetNull)
  receipts      SalesOrderPurchaseReceipt[]

  @@index([salesOrderId, sortOrder])
  @@index([salesOrderId, purchasedBy])
}

model SalesOrderPurchaseReceipt {
  id            String               @id @default(cuid())
  purchaseItemId String
  fileName      String
  mimeType      String
  fileData      Bytes
  createdAt     DateTime             @default(now())

  purchaseItem  SalesOrderPurchaseItem @relation(fields: [purchaseItemId], references: [id], onDelete: Cascade)

  @@index([purchaseItemId, createdAt])
}

model LoadList {
  id           String         @id @default(cuid())
  salesOrderId String
  name         String         @default("Load List")
  createdById  String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  salesOrder   SalesOrder     @relation(fields: [salesOrderId], references: [id], onDelete: Cascade)
  items        LoadListItem[]
}

model LoadListItem {
  id               String          @id @default(cuid())
  loadListId       String
  salesOrderLineId String?
  item             String
  qty              Int             @default(1)
  sortOrder        Int             @default(0)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  loadList         LoadList        @relation(fields: [loadListId], references: [id], onDelete: Cascade)
  salesOrderLine   SalesOrderLine? @relation(fields: [salesOrderLineId], references: [id], onDelete: SetNull)

  @@index([loadListId, sortOrder])
}

model PurchaseOrder {
  id            String              @id @default(cuid())
  poNumber      String              @unique
  opportunityId String?
  lines         PurchaseOrderLine[]
  tasks         Task[]
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
}

model PurchaseOrderLine {
  id               String          @id @default(cuid())
  purchaseOrderId  String
  vendorId         String
  salesOrderLineId String?
  description      String
  qty              Int
  unitCost         Decimal         @db.Decimal(12, 2)
  purchaseOrder    PurchaseOrder   @relation(fields: [purchaseOrderId], references: [id])
  vendor           Vendor          @relation(fields: [vendorId], references: [id])
  salesOrderLine   SalesOrderLine? @relation(fields: [salesOrderLineId], references: [id])
}

model Project {
  id            String      @id @default(cuid())
  name          String
  opportunityId String
  opportunity   Opportunity @relation(fields: [opportunityId], references: [id])
  tasks         Task[]
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model Job {
  id               String         @id @default(cuid())
  companyId        String?
  name             String
  opportunityId    String
  salesOrderId     String?
  salesOrderLineId String?
  opportunity      Opportunity    @relation(fields: [opportunityId], references: [id])
  company          Company?       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  salesOrder       SalesOrder?    @relation(fields: [salesOrderId], references: [id], onDelete: SetNull)
  salesOrderLine   SalesOrderLine? @relation(fields: [salesOrderLineId], references: [id], onDelete: SetNull)
  tasks            Task[]
  timeEntries      TimeEntry[]
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@index([companyId, salesOrderId])
  @@index([salesOrderLineId])
}

model Task {
  id         String     @id @default(cuid())
  title      String
  status     TaskStatus @default(TODO)
  assigneeId String?
  entityType EntityType
  entityId   String
  dueAt      DateTime?
  assignee   User?      @relation(fields: [assigneeId], references: [id])

  opportunityId   String?
  quoteId         String?
  salesOrderId    String?
  purchaseOrderId String?
  projectId       String?
  jobId           String?

  opportunity   Opportunity?   @relation(fields: [opportunityId], references: [id])
  quote         Quote?         @relation(fields: [quoteId], references: [id])
  salesOrder    SalesOrder?    @relation(fields: [salesOrderId], references: [id])
  purchaseOrder PurchaseOrder? @relation(fields: [purchaseOrderId], references: [id])
  project       Project?       @relation(fields: [projectId], references: [id])
  job           Job?           @relation(fields: [jobId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Note {
  id          String     @id @default(cuid())
  body        String
  entityType  EntityType
  entityId    String
  createdById String?
  createdBy   User?      @relation(fields: [createdById], references: [id])
  mentions    NoteMention[]
  createdAt   DateTime   @default(now())
}

model NoteMention {
  id              String   @id @default(cuid())
  noteId          String
  mentionedUserId String
  createdAt       DateTime @default(now())

  note            Note     @relation(fields: [noteId], references: [id], onDelete: Cascade)
  mentionedUser   User     @relation(fields: [mentionedUserId], references: [id], onDelete: Cascade)

  @@unique([noteId, mentionedUserId])
  @@index([mentionedUserId, createdAt])
}

model NotificationPreference {
  id                           String            @id @default(cuid())
  companyId                    String?
  userId                       String
  event                        NotificationEvent
  emailEnabled                 Boolean           @default(true)
  inAppEnabled                 Boolean           @default(true)
  createdAt                    DateTime          @default(now())
  updatedAt                    DateTime          @updatedAt

  company                      Company?          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user                         User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([companyId, userId, event])
  @@index([userId, event])
}

model Proof {
  id               String                 @id @default(cuid())
  quoteLineId      String?
  salesOrderLineId String?
  version          Int                    @default(1)
  fileName         String
  mimeType         String
  fileData         Bytes
  status           ProofStatus            @default(PENDING)
  approvalNotes    String?
  approvedAt       DateTime?
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt
  quoteLine        QuoteLine?             @relation(fields: [quoteLineId], references: [id])
  salesOrderLine   SalesOrderLine?        @relation(fields: [salesOrderLineId], references: [id])
  requests         ProofApprovalRequest[]
}

model ProofApprovalRequest {
  id             String       @id @default(cuid())
  proofId        String
  recipientEmail String
  token          String       @unique
  expiresAt      DateTime
  respondedAt    DateTime?
  decision       ProofStatus?
  responseNotes  String?
  createdAt      DateTime     @default(now())
  proof          Proof        @relation(fields: [proofId], references: [id], onDelete: Cascade)
}

model TaskTemplate {
  id        String             @id @default(cuid())
  companyId String?
  name      String
  active    Boolean            @default(true)
  company   Company?           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  steps     TaskTemplateStep[]
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  @@unique([companyId, name])
}

model TaskTemplateStep {
  id                 String               @id @default(cuid())
  templateId         String
  title              String
  sortOrder          Int                  @default(0)
  dueOffsetDays      Int                  @default(0)
  assigneeMode       TemplateAssigneeMode @default(UNASSIGNED)
  specificAssigneeId String?
  template           TaskTemplate         @relation(fields: [templateId], references: [id])
  specificAssignee   User?                @relation("TemplateSpecificAssignee", fields: [specificAssigneeId], references: [id])
}

model JobWorkflowTemplate {
  id        String               @id @default(cuid())
  companyId String?
  name      String
  active    Boolean              @default(true)
  company   Company?             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  steps     JobWorkflowStep[]
  runs      JobWorkflowRun[]
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt

  @@unique([companyId, name])
}

model JobWorkflowStep {
  id               String               @id @default(cuid())
  workflowId       String
  name             String
  sortOrder        Int                  @default(0)
  assigneeMode     TemplateAssigneeMode @default(UNASSIGNED)
  specificAssigneeId String?
  workflow         JobWorkflowTemplate  @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  specificAssignee User?                @relation("WorkflowTemplateSpecificAssignee", fields: [specificAssigneeId], references: [id], onDelete: SetNull)

  @@index([workflowId, sortOrder])
}

model JobWorkflowRun {
  id                        String             @id @default(cuid())
  companyId                 String?
  workflowTemplateId        String
  entityType                EntityType
  entityId                  String
  status                    TaskStatus         @default(TODO)
  currentStepSortOrder      Int?
  projectManagerUserId      String?
  projectCoordinatorUserId  String?
  createdAt                 DateTime           @default(now())
  updatedAt                 DateTime           @updatedAt

  company                   Company?           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  workflowTemplate          JobWorkflowTemplate @relation(fields: [workflowTemplateId], references: [id], onDelete: Cascade)
  steps                     JobWorkflowStepRun[]

  @@index([companyId, entityType, entityId])
}

model JobWorkflowStepRun {
  id              String      @id @default(cuid())
  workflowRunId   String
  stepName        String
  sortOrder       Int
  assigneeMode    TemplateAssigneeMode @default(UNASSIGNED)
  assigneeId      String?
  status          TaskStatus  @default(TODO)
  activatedAt     DateTime?
  completedAt     DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  workflowRun     JobWorkflowRun @relation(fields: [workflowRunId], references: [id], onDelete: Cascade)
  assignee        User?          @relation("WorkflowStepAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)

  @@unique([workflowRunId, sortOrder])
  @@index([workflowRunId, status, sortOrder])
}

model Traveler {
  id                    String    @id @default(cuid())
  companyId             String?
  userId                String?
  fullName              String
  email                 String?
  phone                 String?
  emergencyName         String?
  emergencyRelationship String?
  emergencyPhone        String?
  dateOfBirth           DateTime?
  knownTravelerNumber   String?
  passportNumber        String?
  passportExpiration    DateTime?
  passportCountry       String?
  dietaryNotes          String?
  medicalNotes          String?
  loyaltyAirline        String?
  loyaltyHotel          String?
  loyaltyRentalCar      String?
  managerUserId         String?
  active                Boolean   @default(true)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  company      Company?       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user         User?          @relation(fields: [userId], references: [id], onDelete: SetNull)
  manager      User?          @relation("TripManager", fields: [managerUserId], references: [id], onDelete: SetNull)
  tripLinks    TripTraveler[]
  tripSegments TripSegment[]

  @@index([companyId, fullName])
}

model Trip {
  id               String     @id @default(cuid())
  companyId        String?
  name             String
  projectRef       String?
  destinations     String?
  destinationCity  String?
  destinationState String?
  purpose          String?
  startDate        DateTime?
  endDate          DateTime?
  status           TripStatus @default(PLANNING)
  billable         Boolean    @default(false)
  salesOrderRef    String?
  createdByUserId  String?
  approvedByUserId String?
  approvedAt       DateTime?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  company        Company?       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdByUser  User?          @relation("TripCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)
  approvedByUser User?          @relation("TripApprover", fields: [approvedByUserId], references: [id], onDelete: SetNull)
  travelers      TripTraveler[]
  segments       TripSegment[]
  perDiemRequests PerDiemRequest[]

  @@index([companyId, startDate, endDate])
}

model TripTraveler {
  id         String   @id @default(cuid())
  tripId     String
  travelerId String
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  trip     Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
  traveler Traveler @relation(fields: [travelerId], references: [id], onDelete: Cascade)

  @@unique([tripId, travelerId])
}

model TripSegment {
  id               String            @id @default(cuid())
  tripId           String
  travelerId       String?
  segmentType      TravelSegmentType
  provider         String?
  confirmationCode String?
  startAt          DateTime?
  endAt            DateTime?
  origin           String?
  destination      String?
  address          String?
  notes            String?
  estimatedCost    Decimal?          @db.Decimal(12, 2)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  trip     Trip      @relation(fields: [tripId], references: [id], onDelete: Cascade)
  traveler Traveler? @relation(fields: [travelerId], references: [id], onDelete: SetNull)

  @@index([tripId, segmentType])
}

model PerDiemRequest {
  id                String               @id @default(cuid())
  companyId         String?
  tripId            String
  status            PerDiemRequestStatus @default(NEW)
  destinationCity   String?
  destinationState  String?
  year              Int?
  dailyRate         Decimal?             @db.Decimal(12, 2)
  lodgingRate       Decimal?             @db.Decimal(12, 2)
  days              Int?
  travelerCount     Int?
  total             Decimal?             @db.Decimal(12, 2)
  notes             String?
  createdByUserId   String?
  completedAt       DateTime?
  canceledAt        DateTime?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  company       Company? @relation(fields: [companyId], references: [id], onDelete: Cascade)
  trip          Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
  createdByUser User?    @relation("PerDiemRequestCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([companyId, status, createdAt])
  @@index([tripId, createdAt])
}

model ExpenseReport {
  id               String              @id @default(cuid())
  companyId        String?
  reportNumber     String
  title            String
  employeeName     String
  employeeUserId   String?
  status           ExpenseReportStatus @default(DRAFT)
  periodStart      DateTime?
  periodEnd        DateTime?
  notes            String?
  amexLinked       Boolean             @default(false)
  amexLastSyncAt   DateTime?
  submittedAt      DateTime?
  approvedAt       DateTime?
  reimbursedAt     DateTime?
  rejectedAt       DateTime?
  createdByUserId  String?
  approvedByUserId String?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  company          Company?            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdByUser    User?               @relation("ExpenseReportCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)
  approvedByUser   User?               @relation("ExpenseReportApprover", fields: [approvedByUserId], references: [id], onDelete: SetNull)
  employeeUser     User?               @relation("ExpenseReportEmployee", fields: [employeeUserId], references: [id], onDelete: SetNull)
  lines            ExpenseLine[]

  @@unique([companyId, reportNumber])
  @@index([companyId, status, createdAt])
}

model ExpenseLine {
  id                String            @id @default(cuid())
  expenseReportId   String
  expenseDate       DateTime
  merchant          String
  category          String
  description       String?
  paymentMethod     String?
  amount            Decimal           @db.Decimal(12, 2)
  taxAmount         Decimal?          @db.Decimal(12, 2)
  currency          String            @default("USD")
  receiptRef        String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  expenseReport     ExpenseReport     @relation(fields: [expenseReportId], references: [id], onDelete: Cascade)
  receipts          ExpenseReceipt[]
  matchedAmexTxns   AmexTransaction[] @relation("MatchedExpenseLine")

  @@index([expenseReportId, expenseDate])
}

model ExpenseReceipt {
  id            String      @id @default(cuid())
  expenseLineId String
  fileName      String
  mimeType      String
  fileData      Bytes
  createdAt     DateTime    @default(now())

  expenseLine   ExpenseLine @relation(fields: [expenseLineId], references: [id], onDelete: Cascade)

  @@index([expenseLineId, createdAt])
}

model AmexTransaction {
  id               String                @id @default(cuid())
  companyId        String?
  postedAt         DateTime
  merchant         String
  amount           Decimal               @db.Decimal(12, 2)
  currency         String                @default("USD")
  reference        String?
  source           String?               @default("manual")
  status           AmexTransactionStatus @default(UNMATCHED)
  expenseLineId    String?
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt

  company          Company?              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  expenseLine      ExpenseLine?          @relation("MatchedExpenseLine", fields: [expenseLineId], references: [id], onDelete: SetNull)

  @@index([companyId, status, postedAt])
}

model TimeEntry {
  id             String              @id @default(cuid())
  companyId      String?
  userId         String
  sourceType     TimeEntrySourceType
  salesOrderId   String?
  quoteId        String?
  jobId          String?
  clockInAt      DateTime
  clockOutAt     DateTime?
  minutesWorked  Int?
  status         TimeEntryStatus     @default(PENDING)
  notes          String?
  approvalNote   String?
  approvedById   String?
  approvedAt     DateTime?
  lastEditedById String?
  lastEditedAt   DateTime?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  company        Company?            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user           User                @relation("TimeEntryUser", fields: [userId], references: [id], onDelete: Cascade)
  approvedBy     User?               @relation("TimeEntryApprover", fields: [approvedById], references: [id], onDelete: SetNull)
  lastEditedBy   User?               @relation("TimeEntryEditor", fields: [lastEditedById], references: [id], onDelete: SetNull)
  salesOrder     SalesOrder?         @relation(fields: [salesOrderId], references: [id], onDelete: SetNull)
  quote          Quote?              @relation(fields: [quoteId], references: [id], onDelete: SetNull)
  job            Job?                @relation(fields: [jobId], references: [id], onDelete: SetNull)

  @@index([companyId, userId, clockInAt])
  @@index([companyId, status, clockInAt])
  @@index([userId, clockOutAt])
}

model PayPeriodLock {
  id          String    @id @default(cuid())
  companyId   String?
  startDate   DateTime
  endDate     DateTime
  note        String?
  lockedById  String
  lockedAt    DateTime  @default(now())

  company     Company?  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  lockedBy    User      @relation("PayPeriodLockCreator", fields: [lockedById], references: [id], onDelete: Cascade)

  @@index([companyId, startDate, endDate])
}

model PayrollExportConfig {
  id                    String   @id @default(cuid())
  companyId             String?  @unique
  paycomEarningCode     String   @default("REG")
  defaultDepartmentCode String?
  employeeCodeField     String   @default("USER_ID")
  departmentMap         Json?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  company               Company? @relation(fields: [companyId], references: [id], onDelete: Cascade)
}
